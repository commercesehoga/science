}
.s-btn-primary:hover { box-shadow: 0 10px 28px rgba(26,111,196,0.55); }

.s-btn-green {
    background: linear-gradient(135deg, #22c55e, #15803d);
    color: white; box-shadow: 0 6px 20px rgba(34,197,94,0.35);
}
