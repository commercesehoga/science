/* ============================================================
   TEST ENGINE
   ============================================================ */
let currentQuestionIndex = 0;
let timeLeft = mockTest.duration;
let timer;
let testSubmitted = false;
let testStarted = false;

const timerEl = document.querySelector('.timer');
const questionTextEl = document.getElementById('question-text');
const optionsEl = document.getElementById('options-container');
const qNumEl = document.getElementById('q-number');
const curQNumEl = document.getElementById('current-q-number');
const progressFill = document.getElementById('test-progress');
const progressPct = document.getElementById('progress-percent');
const paletteGrid = document.getElementById('question-palette-grid');
const answeredCountEl = document.getElementById('answered-count');
const prevBtn = document.getElementById('prev-btn');
const nextBtn = document.getElementById('next-btn');
const markBtn = document.getElementById('mark-btn');
const submitBtn = document.getElementById('submit-test-btn');
const modal = document.getElementById('results-modal');
const closeModal = document.getElementById('close-modal');
const reviewBtn = document.getElementById('review-btn');

function initTest() {
    renderPalette();
    renderQuestion();
    startTimer();
    updateProgress();
    renderLegend(false);
    prevBtn.addEventListener('click', () => { if (currentQuestionIndex > 0) { currentQuestionIndex--; renderQuestion(); } });
    nextBtn.addEventListener('click', () => { if (currentQuestionIndex < mockTest.questions.length - 1) { currentQuestionIndex++; renderQuestion(); } });
    markBtn.addEventListener('click', toggleMark);
    submitBtn.addEventListener('click', () => { if (confirm('Submit the test?')) submitTest(); });
    closeModal.addEventListener('click', () => modal.classList.remove('show'));
    reviewBtn.addEventListener('click', () => { modal.classList.remove('show'); currentQuestionIndex = 0; renderQuestion(); });
    document.getElementById('download-pdf-btn').addEventListener('click', generatePDF);
    document.getElementById('modal-result-btn').addEventListener('click', () => { modal.classList.remove('show'); document.getElementById('stream-picker-overlay').style.display = 'flex'; });
    document.getElementById('pdf-action-btn').addEventListener('click', generatePDF);
    document.getElementById('result-action-btn').addEventListener('click', () => { document.getElementById('stream-picker-overlay').style.display = 'flex'; });
}

function startTimer() {
    updateTimerDisplay();
    timer = setInterval(() => {
        timeLeft--;
        updateTimerDisplay();
        if (timeLeft <= 0) { clearInterval(timer); submitTest(); }
        if (timeLeft === 300) alert('⚠️ Only 5 minutes remaining!');
    }, 1000);
}

function updateTimerDisplay() {
    const h = Math.floor(timeLeft / 3600);
    const m = Math.floor((timeLeft % 3600) / 60);
    const s = timeLeft % 60;
    const str = `${pad(h)}:${pad(m)}:${pad(s)}`;
    timerEl.textContent = str;
    const mob = document.querySelector('.mob-timer');
    if (mob) mob.textContent = str;
}
function pad(n) { return String(n).padStart(2, '0'); }

function renderQuestion() {
    const q = mockTest.questions[currentQuestionIndex];
    document.getElementById('current-section').textContent = q.section;
    document.getElementById('section-badge').textContent = '📘 ' + q.section;
    questionTextEl.textContent = q.text;
    qNumEl.textContent = q.id;
    curQNumEl.textContent = q.id;
    optionsEl.innerHTML = '';

if (q.type === "image-options") {
        q.options.forEach((opt, i) => {
            const div = document.createElement('div');
            div.className = 'option';
            if (testSubmitted) {
                if (i === q.correct) div.classList.add('correct');
                else if (i === q.userAnswer) div.classList.add('incorrect');
            } else {
                if (i === q.userAnswer) div.classList.add('selected');
            }
            if (!testSubmitted) {
                div.addEventListener('click', () => {
                    optionsEl.querySelectorAll('.option').forEach(o => o.classList.remove('selected'));
                    div.classList.add('selected');
                    q.userAnswer = i;
                    updatePalette();
                    updateProgress();
                });
            }
            const letter = document.createElement('div');
            letter.className = 'opt-letter';
            letter.textContent = String.fromCharCode(65 + i);
            const svgWrap = document.createElement('div');
            svgWrap.style.flex = '1';
            svgWrap.innerHTML = opt.svg;
            if (testSubmitted) {
                if (i === q.correct) {
                    const ind = document.createElement('span');
                    ind.className = 'opt-indicator correct-indicator';
                    ind.style.display = 'block';
                    ind.style.fontSize = '12px';
                    ind.textContent = '✓ Correct';
                    svgWrap.appendChild(ind);
                } else if (i === q.userAnswer) {
                    const ind = document.createElement('span');
                    ind.className = 'opt-indicator incorrect-indicator';
                    ind.style.display = 'block';
                    ind.style.fontSize = '12px';
                    ind.textContent = '✗ Your Answer';
                    svgWrap.appendChild(ind);
                }
            }
            div.appendChild(letter);
            div.appendChild(svgWrap);
            optionsEl.appendChild(div);
        });
    } else {
        for (const [key, val] of Object.entries(q.options)) {
            const div = document.createElement('div');
            div.className = 'option';
            if (testSubmitted) {
                if (key === q.correctAnswer) div.classList.add('correct');
                else if (key === q.userAnswer) div.classList.add('incorrect');
            } else {
                if (key === q.userAnswer) div.classList.add('selected');
            }
            if (!testSubmitted) {
                div.addEventListener('click', () => {
                    optionsEl.querySelectorAll('.option').forEach(o => o.classList.remove('selected'));
                    div.classList.add('selected');
                    q.userAnswer = key;
                    updatePalette();
                    updateProgress();
                });
            }
            const letter = document.createElement('div');
            letter.className = 'opt-letter';
            letter.textContent = key.toUpperCase();
            const text = document.createElement('span');
            text.className = 'opt-text';
            text.textContent = val;
            if (testSubmitted) {
                if (key === q.correctAnswer) {
                    const ind = document.createElement('span');
                    ind.className = 'opt-indicator correct-indicator';
                    ind.textContent = ' ✓ Correct';
                    text.appendChild(ind);
                } else if (key === q.userAnswer) {
                    const ind = document.createElement('span');
                    ind.className = 'opt-indicator incorrect-indicator';
                    ind.textContent = ' ✗ Your Answer';
                    text.appendChild(ind);
                }
            }
            const radio = document.createElement('input');
            radio.type = 'radio';
            radio.name = 'q-opt';
            radio.value = key;
            radio.checked = q.userAnswer === key;
            div.appendChild(radio);
            div.appendChild(letter);
            div.appendChild(text);
            optionsEl.appendChild(div);
        }
    }

    if (testSubmitted && q.explanation) {
        const exp = document.createElement('div');
        exp.className = 'explanation-box';
        exp.innerHTML = `<strong>Explanation:</strong> ${q.explanation}`;
        optionsEl.appendChild(exp);
    }

    markBtn.classList.toggle('marked', q.marked);
    markBtn.textContent = q.marked ? '🔖 Marked' : '🔖 Mark';
    prevBtn.style.visibility = currentQuestionIndex === 0 ? 'hidden' : 'visible';
    nextBtn.style.visibility = currentQuestionIndex === mockTest.questions.length - 1 ? 'hidden' : 'visible';
    updatePalette();
}

function toggleMark() {
    const q = mockTest.questions[currentQuestionIndex];
    q.marked = !q.marked;
    markBtn.classList.toggle('marked', q.marked);
    markBtn.textContent = q.marked ? '🔖 Marked' : '🔖 Mark';
    updatePalette();
}

function renderPalette() {
    paletteGrid.innerHTML = '';
    mockTest.questions.forEach((q, i) => {
        const btn = document.createElement('button');
        btn.className = 'palette-btn';
        btn.textContent = q.id;
        btn.addEventListener('click', () => { currentQuestionIndex = i; renderQuestion(); });
        paletteGrid.appendChild(btn);
    });
    updatePalette();
}

function updatePalette() {
    const btns = paletteGrid.querySelectorAll('.palette-btn');
    mockTest.questions.forEach((q, i) => {
        const btn = btns[i];
        btn.className = 'palette-btn';
        if (testSubmitted) {
            if (!q.userAnswer) btn.classList.add('review-unanswered');
            else if (q.userAnswer === q.correctAnswer) btn.classList.add('review-correct');
            else btn.classList.add('review-wrong');
        } else {
            if (q.userAnswer) btn.classList.add('answered');
            if (q.marked) btn.classList.add('marked');
        }
        if (i === currentQuestionIndex) btn.classList.add('current');
    });
    const ans = mockTest.questions.filter(q => q.userAnswer).length;
    answeredCountEl.textContent = `${ans}/${mockTest.questions.length}`;
}

function updateProgress() {
    const ans = mockTest.questions.filter(q => q.userAnswer).length;
    const pct = Math.round((ans / mockTest.questions.length) * 100);
    progressFill.style.width = pct + '%';
    progressPct.textContent = pct + '%';
}

function renderLegend(reviewMode) {
    const leg = document.getElementById('palette-legend');
    if (!leg) return;
    if (reviewMode) {
        leg.innerHTML = `
        <div class="leg-label"><div class="leg-dot" style="background:#22c55e;"></div>Correct</div>
        <div class="leg-label"><div class="leg-dot" style="background:#ef4444;"></div>Wrong</div>
        <div class="leg-label"><div class="leg-dot" style="background:#60a5fa;"></div>Unanswered</div>`;
    } else {
        leg.innerHTML = `
        <div class="leg-label"><div class="leg-dot" style="background:#bbf7d0;border:1px solid #22c55e;"></div>Answered</div>
        <div class="leg-label"><div class="leg-dot" style="background:#bae6fd;border:1px solid #0ea5e9;"></div>Marked</div>
        <div class="leg-label"><div class="leg-dot" style="background:#fee2e2;border:1px solid #fca5a5;"></div>Unanswered</div>
        <div class="leg-label"><div class="leg-dot" style="background:white;border:2px solid #1a6fc4;"></div>Current</div>`;
    }
}

function submitTest() {
    if (testSubmitted) return;
    testSubmitted = true;
    clearInterval(timer);

    let correct = 0, incorrect = 0, unanswered = 0;
mockTest.questions.forEach(q => {
        if (q.userAnswer === null || q.userAnswer === undefined || q.userAnswer === '') unanswered++;
        else if (q.type === "image-options" ? q.userAnswer === q.correct : q.userAnswer === q.correctAnswer) correct++;
        else incorrect++;
    });

    const total = mockTest.questions.length;
    const maxScore = total * mockTest.markingScheme.correct;
    const score = (correct * mockTest.markingScheme.correct) + (incorrect * mockTest.markingScheme.incorrect);
    const pct = ((score / maxScore) * 100).toFixed(2);
    const acc = correct + incorrect > 0 ? ((correct / (correct + incorrect)) * 100).toFixed(2) : '0';

const resultData = {
    studentId:  localStorage.getItem('ts_student_id') || '',
    name:       localStorage.getItem('cbtUserName') || 'Unknown',
    subject:    SUBJECT_ID,
    chapter:    CHAPTER_ID,
    date:       new Date().toISOString(),
    score,
    maxScore:   total * mockTest.markingScheme.correct,
    correct,
    wrong:      incorrect,
    incorrect:  incorrect,    // ← ADD: dashboard reads this first
    skipped:    unanswered,
    unanswered: unanswered,   // ← ADD: dashboard reads this first
    totalQ:     total,
    percentage: parseFloat(pct),
    accuracy:   parseFloat(acc),
    timeTaken:  mockTest.duration - timeLeft,
    wrongQs:    mockTest.questions                // ← ADD: for bookmark system
        .map((q, i) => {
            const ans = q.userAnswer;
            const correct_ans = q.type === 'image-options' ? q.correct : q.correctAnswer;
            return (ans !== null && ans !== undefined && ans !== '' && ans !== correct_ans) ? i + 1 : null;
        })
        .filter(Boolean)
};

const storageKey = `thunderstudy_result_${SUBJECT_ID}_${CHAPTER_ID}`;
localStorage.setItem(storageKey, JSON.stringify(resultData));

const GS_URL = "https://script.google.com/macros/s/AKfycbyEsrvdSuRh06TIKPK0ozP-jQNjqHO8PaIeBcW5r45aGdr4H3ZVFHpKMm3xaDHrYmqX/exec";
fetch(GS_URL, {
    method: 'POST',
    mode: 'no-cors',
    headers: { 'Content-Type': 'text/plain' },
    body: JSON.stringify(resultData)
}).then(() => {
    localStorage.setItem(`synced_${SUBJECT_ID}_${CHAPTER_ID}`, 'true');
}).catch(err => console.error('Sheet sync failed:', err));
    const idxKey = `thunderstudy_index_${SUBJECT_ID}`;
    let idx = [];
    try { idx = JSON.parse(localStorage.getItem(idxKey) || '[]'); } catch(e) {}
    if (!idx.includes(CHAPTER_ID)) idx.push(CHAPTER_ID);
    localStorage.setItem(idxKey, JSON.stringify(idx));

    document.getElementById('correct-answers').textContent = correct;
    document.getElementById('incorrect-answers').textContent = incorrect;
    document.getElementById('unanswered').textContent = unanswered;
    document.getElementById('total-score').textContent = score;
    document.getElementById('percentage').textContent = pct;
    document.getElementById('accuracy').textContent = acc;
    modal.classList.add('show');

    renderQuestion();
    renderLegend(true);

    // Swap submit rows
    document.getElementById('submit-row-before').style.display = 'none';
    document.getElementById('submit-row-after').style.display = 'flex';
}

/* Visibility change guard */

document.addEventListener("visibilitychange", () => {
    if (!testStarted || testSubmitted) return;
    updateFocusMode(); // ADD THIS LINE
    if (document.hidden) startCountdown('tab');
    else cancelCountdown();
});

/* Arrow key nav */
document.addEventListener('keydown', e => {
    if (document.getElementById('test-screen').style.display === 'none') return;
    if (e.key === 'ArrowRight' || e.key === 'ArrowDown') { if (currentQuestionIndex < mockTest.questions.length - 1) { currentQuestionIndex++; renderQuestion(); } }
    else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') { if (currentQuestionIndex > 0) { currentQuestionIndex--; renderQuestion(); } }
});
</script>

<script>
  
function startMock() {
    const savedName = localStorage.getItem('cbtUserName') || '';
    const savedSID  = localStorage.getItem('ts_student_id') || '';
    const inputName = document.getElementById('username-input').value.trim();

    if (!savedName && !inputName) {
        alert('⚠️ Please enter your name to continue!');
        document.getElementById('username-input').focus();
        return;
    }
    if (!savedName && inputName) localStorage.setItem('cbtUserName', inputName);

    if (!savedSID) {
        const go = confirm('⚠️ Student ID not found!\n\nYou need a Student ID to start.\nClick OK to open Dashboard, or Cancel to stay.');
        if (go) window.open('https://commercesehoga.github.io/dashboard/', '_blank');
        return;
    }

    enterFullscreen();
    document.getElementById('start-screen').style.display = 'none';
    document.getElementById('instruction-screen').style.display = 'block';
}

document.getElementById('dark-toggle').addEventListener('click', () => {
    document.body.classList.toggle('dark-mode');
    const dark = document.body.classList.contains('dark-mode');
    document.getElementById('toggle-icon').textContent = dark ? '☀️' : '🌙';
    document.getElementById('toggle-label').textContent = dark ? 'Light' : 'Dark';
});

const checkbox = document.getElementById('agree-checkbox');
const startTestBtn = document.getElementById('start-test-btn');
checkbox.addEventListener('change', () => {
    startTestBtn.disabled = !checkbox.checked;
});
startTestBtn.addEventListener('click', () => {
    if (!checkbox.checked) { alert('Please agree to instructions!'); return; }
    const name = localStorage.getItem('cbtUserName') || 'Student';
    const sid  = localStorage.getItem('ts_student_id') || 'N/A';

    document.getElementById('instruction-screen').style.display = 'none';
    document.getElementById('test-screen').style.display = 'block';
    document.getElementById('user-name-display').textContent = '👤 ' + name;

    const mob = document.getElementById('mobile-name-display');
    if (mob) mob.textContent = '👤 ' + name + ' | ' + sid;
    if (document.getElementById('display-user-name')) document.getElementById('display-user-name').textContent = name;
    if (document.getElementById('display-user-sid'))  document.getElementById('display-user-sid').textContent  = sid;

    testStarted = true;
    enterFullscreen();
    initTest();
});

function enterFullscreen() {
    const el = document.documentElement;
    try {
        if (el.requestFullscreen) el.requestFullscreen();
        else if (el.webkitRequestFullscreen) el.webkitRequestFullscreen();
        else if (el.mozRequestFullScreen) el.mozRequestFullScreen();
    } catch(e) {}
}

['fullscreenchange','webkitfullscreenchange','mozfullscreenchange','MSFullscreenChange'].forEach(evt => document.addEventListener(evt, onFSChange));

function isFullscreen() {
    return !!(document.fullscreenElement || document.webkitFullscreenElement || document.mozFullScreenElement);
}
function onFSChange() {
    if (!testStarted || testSubmitted) return;
    if (document.getElementById('test-screen').style.display === 'none') return;
    updateFocusMode(); // ADD THIS LINE
    if (!isFullscreen()) startCountdown('fullscreen');
    else cancelCountdown();
}

let cdTimer = null, cdSecs = 0;
function startCountdown(reason) {
    if (!testStarted || testSubmitted || cdTimer) return;
    cdSecs = reason === 'tab' ? 2 : 5;
    const msg = reason === 'tab' ? '⚠️ Tab switched!' : '⚠️ Exited fullscreen!';
    const hint = reason === 'tab' ? 'Return to this tab to cancel.' : 'Click below to return to fullscreen.';
    showOverlay(msg, hint, cdSecs, reason === 'fullscreen');
    cdTimer = setInterval(() => { cdSecs--; updateOverlay(cdSecs); if (cdSecs <= 0) { cancelCountdown(); submitTest(); } }, 1000);
}
function cancelCountdown() {
    if (cdTimer) { clearInterval(cdTimer); cdTimer = null; }
    hideOverlay();
}
function updateFocusMode() {
    const disturbed = document.hidden || !isFullscreen();
    const color = disturbed ? '#ff3d57' : '#00c853';
    const text  = disturbed ? '● Disturbed' : '● Focus On';
    [document.getElementById('focus-laptop'), document.getElementById('focus-mobile')]
        .forEach(el => { if (el) { el.style.color = color; el.textContent = text; } });
}
function showOverlay(msg, hint, secs, btn) {
    let ov = document.getElementById('sec-overlay');
    if (!ov) { ov = document.createElement('div'); ov.id = 'sec-overlay'; ov.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,0.88);z-index:999999;display:flex;flex-direction:column;justify-content:center;align-items:center;font-family:DM Sans,sans-serif;color:#fff;text-align:center;padding:24px;'; document.body.appendChild(ov); }
    ov.innerHTML = `<div style="font-size:56px;margin-bottom:12px;">🚨</div><div style="font-size:22px;font-weight:800;margin-bottom:8px;">${msg}</div><div style="font-size:15px;color:#fbbf24;margin-bottom:18px;">${hint}</div><div style="font-size:14px;color:#e0e0e0;margin-bottom:4px;">Auto-submitting in</div><div id="ov-count" style="font-size:72px;font-weight:900;color:#f87171;line-height:1;">${secs}</div><div style="font-size:13px;color:#9ca3af;margin-top:4px;">seconds</div>${btn?`<button onclick="enterFullscreen()" style="margin-top:22px;padding:12px 32px;border-radius:30px;border:none;background:linear-gradient(135deg,#22c55e,#15803d);color:#fff;font-size:16px;font-weight:700;cursor:pointer;">🔲 Return to Fullscreen</button>`:''}`;
    ov.style.display = 'flex';
}
function updateOverlay(n) { const el = document.getElementById('ov-count'); if (el) el.textContent = n; }
function hideOverlay() { const ov = document.getElementById('sec-overlay'); if (ov) ov.style.display = 'none'; }
</script>

<script>
function generatePDF() {
    const name = localStorage.getItem('cbtUserName') || 'Student';
    const now = new Date();
    const dateStr = now.toLocaleDateString('en-IN', {day:'2-digit',month:'short',year:'numeric'});
    const timeStr = now.toLocaleTimeString('en-IN', {hour:'2-digit',minute:'2-digit'});

    let correct=0,incorrect=0,unanswered=0;
    mockTest.questions.forEach(q => {
        if (!q.userAnswer) unanswered++;
        else if (q.userAnswer === q.correctAnswer) correct++;
        else incorrect++;
    });
    const score = (correct*5)+(incorrect*-1);
    const maxScore = mockTest.questions.length*5;
    const pct = ((score/maxScore)*100).toFixed(1);
    const lbl = {a:'A',b:'B',c:'C',d:'D'};

    let qHTML = '';
    mockTest.questions.forEach((q,i) => {
        const ok = q.userAnswer === q.correctAnswer;
        const wrong = q.userAnswer && !ok;
        const skip = !q.userAnswer;
        const statusColor = ok?'#059669':wrong?'#dc2626':'#9ca3af';
        const statusLabel = ok?'✓ Correct':wrong?'✗ Wrong':'— Skipped';
        const rowBg = ok?'#f0fdf4':wrong?'#fef2f2':'#fafafa';
        let optsHTML='';
        for (const [k,v] of Object.entries(q.options)) {
            const isRight=k===q.correctAnswer, isUser=k===q.userAnswer;
            let bg='transparent',fw='normal',pre='';
            if(isRight){bg='#dcfce7';fw='bold';pre='✓ ';}
            if(isUser&&!isRight){bg='#fee2e2';fw='bold';pre='✗ ';}
            optsHTML+=`<div style="display:flex;gap:8px;padding:4px 8px;border-radius:4px;background:${bg};font-weight:${fw};font-size:12px;margin:2px 0;"><span style="min-width:18px;font-weight:700;">${lbl[k]}.</span><span>${pre}${v}</span></div>`;
        }
        const yourAns = skip?'<span style="color:#9ca3af;">Not Attempted</span>':`<span style="color:${ok?'#059669':'#dc2626'};font-weight:bold;">${lbl[q.userAnswer]}. ${q.options[q.userAnswer]}</span>`;
        qHTML+=`<div style="margin-bottom:16px;padding:14px;border-radius:8px;background:${rowBg};border:1px solid #e5e7eb;page-break-inside:avoid;">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px;">
                <div style="font-weight:700;font-size:13px;color:#1e293b;">Q${i+1}. ${q.text}</div>
                <div style="font-weight:700;font-size:12px;color:${statusColor};white-space:nowrap;margin-left:12px;">${statusLabel}</div>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:2px;margin-bottom:8px;">${optsHTML}</div>
            <div style="font-size:12px;border-top:1px solid #e5e7eb;padding-top:6px;">
                Your answer: ${yourAns}&nbsp;&nbsp;
                Correct: <span style="color:#059669;font-weight:bold;">${lbl[q.correctAnswer]}. ${q.options[q.correctAnswer]}</span>
            </div>
        </div>`;
    });

    const scoreColor = pct>=60?'#059669':pct>=35?'#d97706':'#dc2626';
    const html=`<div style="max-width:780px;margin:0 auto;font-family:Arial,sans-serif;color:#111;">
        <div style="background:linear-gradient(135deg,#1a6fc4,#0ea5e9);color:white;padding:20px 24px;border-radius:10px 10px 0 0;">
            <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px;">
                <div><div style="font-size:22px;font-weight:800;">⚡ Thunderstudy CBT</div><div style="font-size:13px;opacity:0.85;margin-top:3px;">English Result Report</div></div>
                <div style="text-align:right;font-size:12px;opacity:0.85;"><div>📅 ${dateStr} 🕐 ${timeStr}</div><div>👤 ${name}</div></div>
            </div>
        </div>
        <div style="background:#f0f6ff;border:1px solid #bfdbfe;border-top:none;padding:16px 24px;margin-bottom:20px;border-radius:0 0 10px 10px;">
            <div style="display:flex;flex-wrap:wrap;gap:12px;">
                <div style="background:white;border:1px solid #dbeafe;border-radius:8px;padding:10px 18px;text-align:center;"><div style="font-size:11px;color:#6b7280;">SCORE</div><div style="font-size:24px;font-weight:800;color:${scoreColor};">${score}<span style="font-size:14px;color:#6b7280;">/${maxScore}</span></div></div>
                <div style="background:white;border:1px solid #dbeafe;border-radius:8px;padding:10px 18px;text-align:center;"><div style="font-size:11px;color:#6b7280;">PERCENTAGE</div><div style="font-size:24px;font-weight:800;color:${scoreColor};">${pct}%</div></div>
                <div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:8px;padding:10px 18px;text-align:center;"><div style="font-size:11px;color:#059669;">CORRECT</div><div style="font-size:24px;font-weight:800;color:#059669;">${correct}</div></div>
                <div style="background:#fef2f2;border:1px solid #fecaca;border-radius:8px;padding:10px 18px;text-align:center;"><div style="font-size:11px;color:#dc2626;">WRONG</div><div style="font-size:24px;font-weight:800;color:#dc2626;">${incorrect}</div></div>
                <div style="background:#f9fafb;border:1px solid #e5e7eb;border-radius:8px;padding:10px 18px;text-align:center;"><div style="font-size:11px;color:#6b7280;">SKIPPED</div><div style="font-size:24px;font-weight:800;color:#6b7280;">${unanswered}</div></div>
            </div>
        </div>
        <div style="font-size:15px;font-weight:700;color:#1a6fc4;margin-bottom:12px;padding-bottom:6px;border-bottom:2px solid #1a6fc4;">📋 Answer Key</div>
        ${qHTML}
        <div style="text-align:center;margin-top:20px;padding:12px;background:#f0f6ff;border-radius:8px;font-size:12px;color:#6b7280;">Generated by <b>Thunderstudy CBT</b> | t.me/thunderstudy_official | ${dateStr}</div>
    </div>`;

    const w = window.open('','_blank','width=950,height=700,scrollbars=yes');
    if (!w) { alert('Popup blocked! Allow popups and retry.'); return; }
    w.document.write(`<!DOCTYPE html><html><head><meta charset="utf-8"/><title>Thunderstudy_English_${name}</title><style>*{box-sizing:border-box;margin:0;padding:0;}body{font-family:Arial,sans-serif;background:#fff;padding:20px;}@media print{.no-print{display:none!important;}}.print-btn{display:block;margin:0 auto 20px;padding:12px 36px;background:linear-gradient(135deg,#1a6fc4,#0ea5e9);color:white;font-size:16px;font-weight:700;border:none;border-radius:30px;cursor:pointer;}</style></head><body><button class="print-btn no-print" onclick="window.print()">🖨️ Print / Save PDF</button>${html}</body></html>`);
    w.document.close(); w.focus();
}
window.addEventListener('DOMContentLoaded', () => {
    const savedName = localStorage.getItem('cbtUserName') || '';
    const savedSID  = localStorage.getItem('ts_student_id') || '';
    if (savedName) {
        const inp = document.getElementById('username-input');
        if (inp) {
            inp.value = savedName;
            inp.style.background = 'rgba(21,101,192,0.07)';
            inp.style.borderColor = '#1976d2';
            inp.style.color = '#1565c0';
            inp.style.fontWeight = 'bold';
            inp.setAttribute('readonly', true);
            inp.insertAdjacentHTML('afterend',
                `<div style="font-size:11px;color:#1976d2;font-weight:700;margin-top:5px;">✅ Verified Dashboard Profile</div>`
            );
        }
    }
    if (savedSID) {
        // Show SID somewhere on start screen if you want — optional
    }
});
</script>

