.option.selected { border-color: var(--primary-dark); background: #dbeafe; }
body.dark-mode .option.selected { background: #0d2a56; border-color: var(--accent); }

.option.correct { border-color: var(--correct) !important; background: var(--correct-bg) !important; }
.option.incorrect { border-color: var(--incorrect) !important; background: var(--incorrect-bg) !important; }

.opt-letter {
    width: 36px; height: 36px; border-radius: 50%;
    border: 2px solid var(--border); background: var(--off-white);
    display: flex; align-items: center; justify-content: center;
    font-size: 14px; font-weight: 700; color: var(--text-muted);
    flex-shrink: 0; transition: all 0.15s;
}
.option.selected .opt-letter { background: var(--primary); border-color: var(--primary); color: white; }
.option.correct .opt-letter { background: var(--correct); border-color: var(--correct); color: white; }
.option.incorrect .opt-letter { background: var(--incorrect); border-color: var(--incorrect); color: white; }

.opt-text { font-size: 15px; color: var(--text-dark); line-height: 1.5; flex: 1; }
body.dark-mode .opt-text { color: var(--dm-text); }
.option.selected .opt-text { color: var(--primary-dark); font-weight: 600; }
body.dark-mode .option.selected .opt-text { color: var(--accent2); }
.option.correct .opt-text { color: var(--correct); font-weight: 600; }
.option.incorrect .opt-text { color: var(--incorrect); font-weight: 600; }

.opt-indicator { font-size: 12px; font-weight: 700; margin-left: 4px; }
.correct-indicator { color: var(--correct); }
.incorrect-indicator { color: var(--incorrect); }

.explanation-box {
    margin-top: 18px; padding: 14px 18px;
    border-radius: 12px; border-left: 4px solid var(--primary);
    background: linear-gradient(135deg, #eff6ff, #dbeafe);
    font-size: 14px; color: var(--text-mid); line-height: 1.7;
}
body.dark-mode .explanation-box { background: linear-gradient(135deg, var(--dm-surface), var(--dm-surface2)); border-left-color: var(--accent); color: var(--dm-text); }

