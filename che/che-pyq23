.mark-btn-q {
    padding: 9px 18px; border-radius: 10px;
    border: 2px solid var(--accent); background: transparent; color: var(--accent);
    font-size: 13px; font-weight: 700; cursor: pointer; font-family: 'DM Sans', sans-serif;
    transition: all 0.15s;
}
.mark-btn-q.marked { background: var(--accent); color: white; }
.mark-btn-q:hover { background: var(--light-blue); }

