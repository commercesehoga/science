}
.dark-toggle:hover { transform: scale(1.05); }
body.dark-mode .dark-toggle { background: linear-gradient(135deg, #f59e0b, #d97706); box-shadow: 0 4px 14px rgba(245,158,11,0.4); }

/* ===== INSTRUCTION SCREEN ===== */
#instruction-screen {
    position: fixed; inset: 0; z-index: 9999;
    background: var(--white); display: none; overflow-y: auto; padding: 40px 20px;
}
body.dark-mode #instruction-screen { background: var(--dm-bg); }

.instr-wrap { max-width: 700px; margin: 0 auto; }

.instr-title {
    font-family: 'Playfair Display', serif;
