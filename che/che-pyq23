}

.nav-btn {
    padding: 10px 24px; border-radius: 10px; border: 2px solid var(--primary);
    background: transparent; color: var(--primary); font-size: 14px; font-weight: 700;
    cursor: pointer; font-family: 'DM Sans', sans-serif; transition: all 0.18s;
}
.nav-btn:hover { background: var(--light-blue); }
body.dark-mode .nav-btn { border-color: var(--accent2); color: var(--accent2); }
body.dark-mode .nav-btn:hover { background: var(--dm-surface2); }

.next-btn {
    background: linear-gradient(135deg, var(--primary), var(--primary-dark));
