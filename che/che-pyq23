.submit-row {
    display: flex; justify-content: space-between; align-items: center;
    max-width: 600px; margin: 20px auto; gap: 14px; flex-wrap: wrap;
}

.fancy-btn {
    flex: 1; min-width: 140px; padding: 14px; border: none; border-radius: 50px;
    font-size: 15px; font-weight: 700; cursor: pointer; text-align: center;
    text-decoration: none; display: flex; align-items: center; justify-content: center;
    font-family: 'DM Sans', sans-serif; transition: transform 0.18s, box-shadow 0.18s;
