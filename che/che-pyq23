body.dark-mode .palette-header { color: var(--dm-text); }

.palette-count { color: var(--primary); font-weight: 700; }
body.dark-mode .palette-count { color: var(--accent2); }

.palette-grid {
    display: grid; grid-template-columns: repeat(5, 1fr); gap: 7px;
}

.palette-btn {
    aspect-ratio: 1; border-radius: 50%; border: 2px solid #e5e7eb;
    background: #fee2e2; /* unanswered = orange-ish red */
