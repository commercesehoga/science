}
body.dark-mode .instr-title { color: var(--accent2); }

.instr-box {
    background: linear-gradient(135deg, #eff6ff, #dbeafe);
    border: 1.5px solid var(--mid-blue); border-radius: 16px; padding: 28px;
}
body.dark-mode .instr-box { background: linear-gradient(135deg, var(--dm-surface), var(--dm-surface2)); border-color: var(--dm-border); }

.instr-box h3 {
