}
body.dark-mode .q-num-tag { background: var(--dm-surface2); color: var(--accent2); }

.section-badge {
    display: inline-flex; align-items: center;
    background: linear-gradient(135deg, var(--primary), var(--accent));
    color: white; padding: 3px 12px; border-radius: 20px;
    font-size: 11px; font-weight: 600; margin-bottom: 12px;
}

.q-text {
    font-size: 18px; font-weight: 500; color: var(--text-dark);
    line-height: 1.6; margin-bottom: 22px;
}
body.dark-mode .q-text { color: var(--dm-text); }

/* OPTIONS */
.option {
    display: flex; align-items: center; gap: 14px;
    padding: 14px 18px; border: 2px solid var(--border);
    border-radius: 12px; margin-bottom: 10px; cursor: pointer;
    background: white; transition: border-color 0.15s, background 0.15s, transform 0.1s;
    user-select: none;
}
body.dark-mode .option { background: var(--dm-surface2); border-color: var(--dm-border); }
.option:hover { border-color: var(--primary); background: var(--off-white); transform: translateX(4px); }
