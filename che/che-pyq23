}

.test-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 20px; padding-bottom: 14px;
    border-bottom: 2px solid var(--light-blue);
}
body.dark-mode .test-header { border-bottom-color: var(--dm-border); }

.user-badge {
